{
  "id": "openclaw-napcat",
  "name": "NapCat QQ Channel",
  "version": "1.0.0",
  "description": "NapCat (OneBot v11) channel plugin — any group @mention instant reply + whitelisted group periodic patrol",
  "channels": ["napcat"],
  "skills": ["skills/napcat-ops"],
  "capabilities": {
    "proactiveMessaging": true,
    "groupMonitoring": true,
    "autoIntervention": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "host": { "type": "string", "description": "NapCat WebSocket 主机地址", "default": "127.0.0.1" },
      "port": { "type": "number", "description": "NapCat WebSocket 端口", "default": 3001 },
      "accessToken": { "type": "string", "description": "NapCat access token（可选）" },
      "path": { "type": "string", "description": "WebSocket 路径", "default": "/" },
      "monitorGroups": {
        "type": "array",
        "items": { "type": "number" },
        "description": "白名单群号列表，这些群会定期巡检并让 AI 判断是否参与。空数组 = 不主动监控，仅响应 @"
      },
      "autoIntervene": {
        "type": "boolean",
        "default": true,
        "description": "是否启用白名单群的定期巡检（需配合 monitorGroups 使用）"
      },
      "autoInterveneKeywords": {
        "type": "array",
        "items": { "type": "string" },
        "description": "触发自动介入的关键词列表（备用，巡检时 AI 自行判断）"
      },
      "autoIntervenePrompt": {
        "type": "string",
        "description": "巡检时附加给 AI 的额外指引提示词"
      },
      "autoCheckIntervalMs": {
        "type": "number",
        "default": 30000,
        "description": "白名单群巡检时间间隔（毫秒），默认 30 秒"
      },
      "autoCheckMessageThreshold": {
        "type": "number",
        "default": 10,
        "description": "白名单群消息累积数量阈值，达到即触发巡检，默认 10 条"
      },
      "historyLimit": {
        "type": "number",
        "default": 20,
        "description": "会话历史保留条数"
      },
      "rateLimitMs": {
        "type": "number",
        "default": 1000,
        "description": "消息发送间隔（毫秒），防止被限制"
      },
      "renderMarkdownToPlain": {
        "type": "boolean",
        "default": true,
        "description": "是否将 AI 回复中的 Markdown 转为纯文本再发送"
      },
      "whitelistUserIds": {
        "type": "array",
        "items": { "type": "number" },
        "description": "私聊白名单 QQ 号，空数组 = 所有人可私聊"
      },
      "admins": {
        "type": "array",
        "items": { "type": "number" },
        "description": "管理员 QQ 号列表"
      }
    }
  },
  "uiHints": {
    "accessToken": { "label": "Access Token", "sensitive": true },
    "host": { "label": "主机地址", "placeholder": "127.0.0.1" },
    "port": { "label": "端口", "placeholder": "3001" },
    "monitorGroups": { "label": "白名单群号（定期巡检）" },
    "autoIntervene": { "label": "启用定期巡检" },
    "autoCheckIntervalMs": { "label": "巡检间隔（毫秒）", "placeholder": "30000" },
    "autoCheckMessageThreshold": { "label": "巡检消息阈值", "placeholder": "10" },
    "whitelistUserIds": { "label": "私聊白名单 QQ 号" }
  }
}
